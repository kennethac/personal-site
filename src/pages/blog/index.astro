---
import FeedList from '../../components/FeedList.astro';
import BasicLayout from "../../layouts/BasicLayout.astro";
import {getCanonicalPosts, toFeedItem} from '../../util/publishedContent';

const posts = await getCanonicalPosts();
const items = posts.map((entry) => toFeedItem(entry));
---

<BasicLayout title="Blog" description={undefined} mainClasses={["prose"]}>
    <h1>Blog</h1>
    <p>
        Canonical versions of long-form posts live here.
        {' '}
        <a href="/blog/rss.xml">Subscribe to the posts feed</a>.
    </p>
    <section>
        <FeedList items={items} emptyMessage="No posts published yet." />
    </section>
</BasicLayout>
