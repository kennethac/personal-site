---
import FormattedDate from "./FormattedDate.astro";
import type { FeedItem } from "../util/publishedContent";
import { buildPostHistoryPath } from "../util/publishedContent";
import { getImage } from "astro:assets";
import { Icon } from "astro-icon/components";

interface Props {
  items: FeedItem[];
  emptyMessage?: string;
  showKindLabel?: boolean;
}

const {
  items,
  emptyMessage = "Nothing published yet.",
  showKindLabel = false,
} = Astro.props;

function getLabel(item: FeedItem): string {
  switch (item.kind) {
    case "post":
      return "Post";
    case "til":
      return "TIL";
    case "link":
      return "Link";
  }
}
function getIcon(item: FeedItem): string {
  switch (item.kind) {
    case "post":
      return "📝";
    case "til":
      return "💡";
    case "link":
      return "🔗";
  }
}
function getIconName(item: FeedItem): string {
  switch (item.kind) {
    case "post":
      return "mdi:paper-edit-outline";
    case "til":
      return "material-symbols:cognition";
    case "link":
      return "material-symbols:link";
  }
}
---

{
  items.length === 0 ? (
    <p>{emptyMessage}</p>
  ) : (
    <ul class="feed-list l-vstack">
      {items.map((item) => (
        <li>
          <div>
            <div class="feed-header">
              <div class="title-row">
                <h4>
                  {showKindLabel && false && (
                    <Icon class="kind" name={getIconName(item)} />
                  )}
                  <a href={item.href}>{item.title}</a>
                </h4>
                {item.pubDate && <FormattedDate date={item.pubDate} />}
              </div>
            </div>
            <p>{item.description}</p>
            {item.kind === "post" && item.entry.data.version > 1 && (
              <p class="meta">
                <a href={buildPostHistoryPath(item.entry)}>
                  View version history
                </a>
              </p>
            )}
            {item.kind === "link" && (
              <p class="meta">
                Original Author:{" "}
                <a
                  href={item.entry.data.link}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {item.entry.data.author}
                </a>
              </p>
            )}
          </div>
        </li>
      ))}
    </ul>
  )
}

<style>
  .feed-list {
    list-style: none;
    padding-inline-start: 0;
  }

  .feed-list > li {
    display: flex;
    gap: var(--gap-1, 1ch);

    & h4 {
      & > * { 
        display: inline-block;
        margin-inline-end: 0.25rem;
      }

      & > .kind {
        flex-shrink: 0;
        flex-grow: 0;
        font-size: 2rem;
      }
    }
  }

  .feed-list * {
    margin-block-end: 0;
  }

  .title-row > * {
    display: inline-block;
    margin-block-end: 0;
  }

  .title-row > *:not(:last-child) {
    margin-inline-end: 1ch;
  }

  .feed-header + p {
    margin-block-start: 0.25rem;
  }

  .kind {
    color: rgb(var(--gray));
    font-size: var(--step--2);
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin-block: 0.1rem 0 0;
    text-transform: uppercase;
  }

  .meta {
    font-size: var(--step--1);
  }
</style>
